ARG VLLM_VERSION=v0.14.0
ARG PYTHON_BIN=python3

FROM vllm/vllm-openai:${VLLM_VERSION} AS torch-version
ARG PYTHON_BIN
RUN ${PYTHON_BIN} -m pip show torch | awk '/Version/{print $2}' | sed 's/+.*$//' > /torch_version.txt

FROM python:3.12-slim-bookworm AS sources
ARG AIBRIX_REPO=https://github.com/DwyaneShi/aibrix.git
ARG AIBRIX_BRANCH=haiyang/vllm-v0.14.0-integration
ARG PRISKV_REPO=https://github.com/aibrix/PrisKV.git
ARG PRISKV_BRANCH=dev

RUN apt-get update -y \
    && apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    git-lfs \
    wget \
    curl \
    xz-utils \
    bzip2 \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /artifacts/packages /artifacts/sources /artifacts/src /artifacts/wheels && \
    wget -q -O /artifacts/packages/liburing-2.6.tar.gz \
        https://github.com/axboe/liburing/archive/refs/tags/liburing-2.6.tar.gz && \
    wget -q -O /artifacts/packages/ucx-1.19.0-ubuntu20.04-mofed5-cuda12-x86_64.tar.bz2 \
        https://github.com/openucx/ucx/releases/download/v1.19.0/ucx-1.19.0-ubuntu20.04-mofed5-cuda12-x86_64.tar.bz2 && \
    wget -q -O /artifacts/packages/cmake-4.1.3-linux-x86_64.sh \
        https://cmake.org/files/v4.1/cmake-4.1.3-linux-x86_64.sh

RUN git clone --depth 1 --recurse-submodules --shallow-submodules -b ${AIBRIX_BRANCH} ${AIBRIX_REPO} /artifacts/src/aibrix && \
    git clone --depth 1 --recurse-submodules --shallow-submodules -b ${PRISKV_BRANCH} ${PRISKV_REPO} /artifacts/src/priskv

FROM docker.io/pytorch/manylinux2_28-builder:cuda12.1 AS wheel-builder
ARG PYTHON_BIN=/opt/python/cp312-cp312/bin/python
ENV PATH="/opt/python/cp312-cp312/bin:${PATH}"
ENV AIBRIX_TARGET_DEVICE=cuda

COPY --from=torch-version /torch_version.txt /tmp/torch_version.txt
COPY --from=sources /artifacts/src /artifacts/src

RUN ${PYTHON_BIN} -m pip install --index-url=https://bytedpypi.byted.org/simple \
        -r /artifacts/src/aibrix/python/aibrix_kvcache/requirements/build.txt \
        -r /artifacts/src/aibrix/python/aibrix_kvcache/requirements/core.txt && \
    ${PYTHON_BIN} -m pip install --index-url=https://bytedpypi.byted.org/simple torch==$(cat /tmp/torch_version.txt) && rm /tmp/torch_version.txt && \
    cd /artifacts/src/aibrix && \
    ${PYTHON_BIN} -m build python/aibrix_kvcache --wheel --outdir=/artifacts/wheels --no-isolation

FROM sources AS pack
RUN tar -czf /artifacts/sources/aibrix-src.tar.gz -C /artifacts/src/aibrix . && \
    tar -czf /artifacts/sources/priskv-src.tar.gz -C /artifacts/src/priskv . && \
    rm -rf /artifacts/src/aibrix /artifacts/src/priskv

FROM scratch AS artifacts
COPY --from=pack /artifacts/sources /artifacts/sources
COPY --from=pack /artifacts/packages /artifacts/packages
COPY --from=wheel-builder /artifacts/wheels /artifacts/wheels
COPY build/container/vllm-configs/ /artifacts/vllm-configs/

FROM debian:bookworm-slim AS debug
COPY --from=artifacts /artifacts /artifacts
